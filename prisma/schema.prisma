// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Muscle {
  id   Int    @id @default(autoincrement())
  name String @unique

  Excercise   Excercise? @relation(fields: [excerciseId], references: [id])
  excerciseId Int?
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
}

// Describes an excercise
model Excercise {
  id Int @id @default(autoincrement())

  name    String   @unique
  muscles Muscle[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
}

model Set {
  id       Int     @id @default(autoincrement())
  duration String?
  weight   String?
  reps     String?

  workout   Workout @relation(fields: [workoutId], references: [id])
  workoutId Int
}

model Workout {
  id          Int   @id @default(autoincrement())
  excersiceId Int
  sets        Set[]

  routine   Routine @relation(fields: [routineId], references: [id])
  routineId Int
}

model Routine {
  id Int @id @default(autoincrement())

  name     String
  workouts Workout[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
}

model Meal {
  id   Int    @id @default(autoincrement())
  name String

  servingSize String // 175 g
  servings    Int // 1 
  calories    Float
  notes       String
  mealType    String // Breakfast, Lunch, Dinner, Snack, other
  // calorioes?
  // kilojoule?

  //nutrients Nutrition[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
}


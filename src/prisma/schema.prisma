// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Muscle {
  id   Int    @id @default(autoincrement())
  name String @unique

  Excercise   Exercise? @relation(fields: [excerciseId], references: [id])
  excerciseId Int?
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?

  createdAt      DateTime         @default(now()) @map(name: "created_at")
  updatedAt      DateTime         @updatedAt @map(name: "updated_at")
  ExercisePlan   ExercisePlan[]
  ExerciseRecord ExerciseRecord[]
  Meal           Meal[]
  WeightRecord   WeightRecord[]
}

// Describes an excercise
model Exercise {
  id Int @id @default(autoincrement())

  name    String   @unique
  muscles Muscle[]

  createdAt      DateTime         @default(now()) @map(name: "created_at")
  updatedAt      DateTime         @updatedAt @map(name: "updated_at")
  ExercisePlan   ExercisePlan[]
  ExerciseRecord ExerciseRecord[]
}

model Set {
  id       Int     @id @default(autoincrement())
  duration String?
  weight   String?
  reps     String?

  workout   Workout @relation(fields: [workoutId], references: [id])
  workoutId Int
}

model Workout {
  id          Int   @id @default(autoincrement())
  excersiceId Int
  sets        Set[]

  routine   Routine @relation(fields: [routineId], references: [id])
  routineId Int
}

model Routine {
  id Int @id @default(autoincrement())

  name     String
  workouts Workout[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
}

model ExercisePlan {
  id          Int      @id @default(autoincrement())
  day         DateTime
  sets        Int
  repetitions Int
  exerciseId  Int
  userId      Int
  Exercise    Exercise @relation(fields: [exerciseId], references: [id])
  User        User     @relation(fields: [userId], references: [id])
}

model ExerciseRecord {
  id          Int      @id @default(autoincrement())
  day         DateTime
  sets        Int
  repetitions Int
  exerciseId  Int
  userId      Int
  Exercise    Exercise @relation(fields: [exerciseId], references: [id])
  User        User     @relation(fields: [userId], references: [id])
}

model Meal {
  id    Int      @id @default(autoincrement())
  name  String
  notes String?
  time  DateTime

  servingSize String // 175 g
  servings    Int // 1 
  calories    Float
  mealType    String // Breakfast, Lunch, Dinner, Snack, other

  userId        Int
  User          User            @relation(fields: [userId], references: [id])
  NutritionInfo NutritionInfo[]
  // calorioes?
  // kilojoule?

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
}

model WeightRecord {
  id     Int      @id @default(autoincrement())
  date   DateTime
  weight Float
  userId Int
  User   User     @relation(fields: [userId], references: [id])
}

//TODO: need to add sub nutritions eg. carbs can be broken down into sugars, starch, dietry fibers
model Nutrition {
  id            Int             @id @default(autoincrement())
  name          String
  NutritionInfo NutritionInfo[]
}

model NutritionInfo {
  id          Int       @id @default(autoincrement())
  amount      Float
  mealId      Int
  nutritionId Int
  Meal        Meal      @relation(fields: [mealId], references: [id])
  Nutrition   Nutrition @relation(fields: [nutritionId], references: [id])
}


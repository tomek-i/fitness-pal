// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String

  Profile     Profile?
  FitnessData FitnessData[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
}

model FitnessData {
  id Int @id @default(autoincrement())

  ExercisePlan   ExercisePlan[]
  ExerciseRecord ExerciseRecord[]
  Meal           Meal[]
  WeightRecord   WeightRecord[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  userId Int
  User   User @relation(fields: [userId], references: [id])
}

model Profile {
  userId Int  @id
  User   User @relation(fields: [userId], references: [id])

  name   String?
  age    Int?
  weight Float? //in kg
  height Int? //in centimeters

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
}

model Muscle {
  id   Int    @id @default(autoincrement())
  name String @unique

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  Excercise   Exercise? @relation(fields: [excerciseId], references: [id])
  excerciseId Int?
}

model Exercise {
  id Int @id @default(autoincrement())

  name String @unique

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  muscles        Muscle[]
  ExercisePlan   ExercisePlan[]
  ExerciseRecord ExerciseRecord[]
}

model Set {
  id       Int     @id @default(autoincrement())
  duration String?
  weight   String?
  reps     String?

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  workoutId Int
  workout   Workout @relation(fields: [workoutId], references: [id])
}

model Workout {
  id          Int   @id @default(autoincrement())
  excersiceId Int
  sets        Set[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  routineId Int
  routine   Routine @relation(fields: [routineId], references: [id])
}

model Routine {
  id Int @id @default(autoincrement())

  name     String
  workouts Workout[]

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
}

model ExercisePlan {
  id          Int      @id @default(autoincrement())
  day         DateTime
  sets        Int
  repetitions Int

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  // userId        Int
  // User          User         @relation(fields: [userId], references: [id])
  exerciseId    Int
  Exercise      Exercise     @relation(fields: [exerciseId], references: [id])
  fitnessDataId Int?
  FitnessData   FitnessData? @relation(fields: [fitnessDataId], references: [id])
}

model ExerciseRecord {
  id          Int      @id @default(autoincrement())
  day         DateTime
  sets        Int
  repetitions Int

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  // userId        Int
  // User          User         @relation(fields: [userId], references: [id])
  exerciseId    Int
  Exercise      Exercise     @relation(fields: [exerciseId], references: [id])
  fitnessDataId Int?
  FitnessData   FitnessData? @relation(fields: [fitnessDataId], references: [id])
}

model Meal {
  id    Int      @id @default(autoincrement())
  name  String
  notes String?
  time  DateTime

  servingSize String // 175 g
  servings    Int // 1 
  calories    Float
  mealType    String // Breakfast, Lunch, Dinner, Snack, other

  // userId        Int
  // User          User            @relation(fields: [userId], references: [id])
  NutritionInfo NutritionInfo[]
  // calorioes?
  // kilojoule?

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  FitnessData   FitnessData? @relation(fields: [fitnessDataId], references: [id])
  fitnessDataId Int?
}

model WeightRecord {
  id     Int      @id @default(autoincrement())
  date   DateTime
  weight Float

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  // userId        Int
  // User          User         @relation(fields: [userId], references: [id])
  fitnessDataId Int?
  FitnessData   FitnessData? @relation(fields: [fitnessDataId], references: [id])
}

//TODO: need to add sub nutritions eg. carbs can be broken down into sugars, starch, dietry fibers
model Nutrition {
  id   Int    @id @default(autoincrement())
  name String

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  NutritionInfo NutritionInfo[]
}

model NutritionInfo {
  id     Int   @id @default(autoincrement())
  amount Float

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  mealId      Int
  Meal        Meal      @relation(fields: [mealId], references: [id])
  nutritionId Int
  Nutrition   Nutrition @relation(fields: [nutritionId], references: [id])
}

